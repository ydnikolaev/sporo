---
// The page shell: the <html>/<head>/<body> frame every page shares, so a page file is just its
// <main> plus the head data. `head` is forwarded to BaseHead; `active` marks the nav. The footer
// is the same on every page (it reads the shared nav itself), so it takes no per-page props. The
// body is a flex column with the <main> frame flexed to fill, so on a short page the footer sits
// at the bottom of the viewport instead of floating mid-screen.
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import ScrollTop from './ScrollTop.astro';

const { head, active } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="auto">
  <head>
    <BaseHead {...head} />
  </head>
  <body>
    <div style="background:var(--bg);color:var(--ink);min-height:100vh;display:flex;flex-direction:column;font-family:'Archivo',-apple-system,'Helvetica Neue',sans-serif;font-size:1.04rem;line-height:1.62;-webkit-font-smoothing:antialiased;overflow-x:clip">
      <Header active={active} />
      <slot />
      <Footer />
    </div>
    <ScrollTop />
  </body>
</html>
