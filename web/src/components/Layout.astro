---
// The page shell: the <html>/<head>/<body> frame every page shares, so a page file is just its
// <main> plus the head/footer data. `head` is forwarded to BaseHead; `active` marks the nav;
// `footer` is forwarded to Footer. A page's interactive scripts (the home page's three) go in
// the named `scripts` slot, which Astro bundles locally.
import BaseHead from './BaseHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';

const { head, active, footer } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...head} />
  </head>
  <body>
    <div data-theme="auto" style="background:var(--bg);color:var(--ink);min-height:100vh;font-family:'Archivo',-apple-system,'Helvetica Neue',sans-serif;font-size:1.04rem;line-height:1.62;-webkit-font-smoothing:antialiased;overflow-x:clip">
      <Header active={active} />
      <slot />
      <Footer {...footer} />
    </div>
  </body>
</html>
