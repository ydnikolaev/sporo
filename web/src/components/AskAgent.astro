---
// The "hand this page to an agent" control — sporo's whole thesis is that agents read this, so a
// give-it-to-your-agent affordance is the product's ethos as UI, not a bolt-on. A split control:
// the primary action copies the page AS MARKDOWN (universal — works with any agent, no lock-in,
// the on-brand default), and a <details> menu carries the secondary ways in. Built on
// <details>/<summary> so it needs no JS to open and is accessible by default (same primitive as
// the compare FAQ). No MCP items: sporo has no server, and the absence is the statement.
//
// Deep-link contracts were verified against each provider's own docs (2026-07):
//   ChatGPT — https://chatgpt.com/?q=<prompt> opens a prefilled chat in a desktop browser (the
//             q= param does NOT prefill inside the mobile app).
//   Claude  — claude://claude.ai/new?q=<prompt> needs the Claude Desktop app installed; the old
//             web claude.ai/new?q= was removed ~Oct-2025, so there is no plain-web fallback. q is
//             truncated to ~14k chars. Both are secondary to Copy page for exactly this fragility.
import { SITE_ORIGIN } from '../lib/site.ts';
interface Props {
  title: string; // the page's title, for the injected prompt
  path: string; // '/docs.html' — the page's canonical path
  mdUrl: string; // 'docs.md' — the markdown twin, relative to the page
  menuOnly?: boolean; // drop the primary "Copy page" and render just a labelled "Ask an agent ▾"
  // menu — for the recipe page, whose recipe-bar already carries copy/download/preview, so a
  // second copy button would compete.
  label?: string; // the menu-only trigger's label
}
const { title, path, mdUrl, menuOnly = false, label = 'Ask an agent' } = Astro.props;
const pageUrl = `${SITE_ORIGIN}${path}`;
const mdAbs = `${SITE_ORIGIN}/${mdUrl}`;
// The context an agent receives: what this page is, one plain line of what sporo is (mechanism, not
// pitch), the page as markdown to read, and a starter. Kept well under Claude's ~14k q= limit.
const prompt = `I'm reading "${title}" on sporo.dev (${pageUrl}). sporo turns a build you already did into a recipe — a self-contained file that teaches an AI agent in a repository that has never seen yours how to rebuild the capability, on its own stack. Here is this page as markdown: ${mdAbs} — read it, then help me understand it and whether sporo fits what I'm building.`;
const q = encodeURIComponent(prompt);
const chatgptUrl = `https://chatgpt.com/?q=${q}`;
const claudeUrl = `claude://claude.ai/new?q=${q}`;

const clip = 'width:14px;height:14px;flex:none';
---

<div class={menuOnly ? 'ask-agent aa-solo-wrap' : 'ask-agent'}>
  {!menuOnly && (
    <button type="button" class="aa-copy" data-md={mdUrl} data-page={title} aria-label="Copy this page as Markdown">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={clip} aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="aa-copy-label">Copy page</span>
    </button>
  )}
  <details class="aa-menu">
    <summary class={menuOnly ? 'aa-toggle aa-solo' : 'aa-toggle'} title={menuOnly ? label : 'More ways to open this page'} aria-label={menuOnly ? label : 'More ways to open this page'}>
      {menuOnly && <span class="aa-solo-label">{label}</span>}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
    </summary>
    <div class="aa-pop">
      <a href={mdUrl} class="aa-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={clip} aria-hidden="true"><path d="M4 4h16v16H4z" opacity="0"/><path d="M4 15V9h2l2 2 2-2h2v6"/><path d="M17 9v4m0 0 2-2m-2 2-2-2"/></svg>
        <span>View as Markdown</span><span class="aa-ext" aria-hidden="true">↗</span>
      </a>
      <button type="button" class="aa-item aa-copylink" data-url={mdAbs}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={clip} aria-hidden="true"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
        <span class="aa-copylink-label">Copy Markdown link</span>
      </button>
      <div class="aa-sep"></div>
      <a href={chatgptUrl} target="_blank" rel="noopener" class="aa-item">
        <svg viewBox="0 0 24 24" fill="currentColor" style={clip} aria-hidden="true"><path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/></svg>
        <span>Ask ChatGPT</span><span class="aa-ext" aria-hidden="true">↗</span>
      </a>
      <a href={claudeUrl} class="aa-item">
        <svg viewBox="0 0 24 24" fill="currentColor" style={clip} aria-hidden="true"><path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"/></svg>
        <span>Ask Claude</span><span class="aa-ext" aria-hidden="true">↗</span>
      </a>
    </div>
  </details>
</div>

<style>
  .ask-agent {
    position: relative;
    display: inline-flex;
    align-items: stretch;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.8rem;
    font-weight: 600;
  }
  /* Split button: Copy | ▾, joined into one control. */
  .aa-copy,
  .aa-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    background: var(--card);
    border: 1px solid var(--line);
    color: var(--ink);
    cursor: pointer;
    padding: 0.5rem 0.85rem;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }
  .aa-copy { border-radius: 0.55rem 0 0 0.55rem; }
  .aa-toggle {
    border-radius: 0 0.55rem 0.55rem 0;
    border-left: none;
    padding: 0.5rem 0.6rem;
    list-style: none;
    color: var(--muted);
  }
  .aa-toggle::-webkit-details-marker { display: none; }
  /* Solo (menu-only) trigger: a full rounded button with its own label, for the recipe bar. */
  .aa-solo {
    border-radius: 0.55rem;
    border-left: 1px solid var(--line);
    gap: 0.42rem;
    padding: 0.5rem 0.85rem;
    color: var(--muted);
    background: var(--bg);
  }
  .aa-solo-wrap { font-size: 0.82rem; }
  .aa-copy:hover,
  .aa-toggle:hover { border-color: var(--accent); color: var(--accent); }
  .aa-menu[open] .aa-toggle { color: var(--accent); border-color: var(--accent); }
  .aa-menu[open] .aa-toggle svg { transform: rotate(180deg); }
  .aa-toggle svg { transition: transform 0.15s ease; }

  .aa-pop {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    z-index: 40;
    min-width: 15.5rem;
    display: flex;
    flex-direction: column;
    padding: 0.35rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 0.7rem;
    box-shadow: 0 12px 32px -12px #00000038;
  }
  .aa-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.6rem;
    border-radius: 0.45rem;
    color: var(--ink);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    font: inherit;
    text-align: left;
    white-space: nowrap;
  }
  .aa-item:hover { background: var(--accent-soft); color: var(--accent); }
  .aa-ext { margin-left: auto; color: var(--muted); }
  .aa-item:hover .aa-ext { color: var(--accent); }
  .aa-sep { height: 1px; background: var(--line); margin: 0.35rem 0.3rem; }

  @media (prefers-reduced-motion: reduce) {
    .aa-copy, .aa-toggle, .aa-item, .aa-toggle svg { transition: none; }
  }
</style>

<script>
  // Flash a button's label to a confirmation for 1.6s, then restore. Kept generic so both the
  // primary copy and the copy-link item reuse it.
  function flash(labelEl: HTMLElement | null, msg: string) {
    if (!labelEl) return;
    const original = labelEl.textContent;
    labelEl.textContent = msg;
    setTimeout(() => {
      labelEl.textContent = original;
    }, 1600);
  }

  // Copy page: hand the clipboard a PROMISE of the markdown via a Promise-valued ClipboardItem, so
  // the write is reserved synchronously inside the click gesture — the only shape Safari accepts
  // when the text comes from a fetch (writeText after an awaited fetch rejects). write() must be
  // the first async call; a swallowed reject is logged, not silent.
  document.querySelectorAll('.aa-copy').forEach((el) => {
    const btn = el as HTMLButtonElement;
    btn.addEventListener('click', async () => {
      const md = btn.dataset.md;
      if (!md) return;
      try {
        if (navigator.clipboard && window.ClipboardItem) {
          await navigator.clipboard.write([
            new ClipboardItem({ 'text/plain': fetch(md).then((r) => r.text()) }),
          ]);
        } else if (navigator.clipboard) {
          await navigator.clipboard.writeText(await (await fetch(md)).text());
        }
        flash(btn.querySelector('.aa-copy-label'), 'Copied ✓');
        if (window.gtag) window.gtag('event', 'copy_page', { page: btn.dataset.page });
      } catch (e) {
        console.warn('copy page failed:', e);
      }
    });
  });

  // Copy markdown link: writing a string we already hold needs no fetch, so plain writeText is
  // safe in every browser (no gesture-consuming await ahead of it).
  document.querySelectorAll('.aa-copylink').forEach((el) => {
    const btn = el as HTMLButtonElement;
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        flash(btn.querySelector('.aa-copylink-label'), 'Copied ✓');
      } catch (e) {
        console.warn('copy link failed:', e);
      }
    });
  });

  // Click-away closes the menu (a bare <details> stays open until re-clicked — fine for keyboard,
  // but a pointer user expects outside-click to dismiss).
  document.addEventListener('click', (e) => {
    document.querySelectorAll('details.aa-menu[open]').forEach((d) => {
      if (!d.contains(e.target as Node)) (d as HTMLDetailsElement).open = false;
    });
  });
</script>
