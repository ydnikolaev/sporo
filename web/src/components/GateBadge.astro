---
// The conformance badge. It claims ONLY what the pipeline mechanically verifies about the shipped
// corpus, and shows the strongest claim that is currently earned:
//
//   - `sealed` (a lock): the recipe still hashes (sha256) to the value committed in
//     `.sporo/registry.yaml`, checked at BUILD by re-hashing the file (see corpus.ts `sealVerified`)
//     and re-checked by CI on every push. It never renders unless the bytes match — a drifted or
//     unsealed recipe falls back to the gate-passed form below.
//   - `gate-passed` (a shield): passes the genre gate — a summary plus eleven sections in order, neutrality
//     (no leaked paths or product names), and earned scars.
//
// It still does NOT claim "no prompt injection / secure": no scan backs that yet. A decorative claim
// is worse than none; when the publish scan lands, its earned badge joins these — see the
// publish-security backlog.
interface Props {
  compact?: boolean; // card form: one word; detail form spells the pair out
  sealed?: boolean; // hash-verified against the committed seal registry
  noun?: 'recipe' | 'seed'; // which genre this badge speaks for — a seed's gate and discipline differ
}
const { compact = false, sealed = false, noun = 'recipe' } = Astro.props;
// The unsealed detail form names the genre's DISCIPLINE: a recipe's is neutrality (names no
// coordinate), a seed's is accountability (accounts for every move it makes on a foreign tree).
const discipline = noun === 'seed' ? 'accountable' : 'neutral';
const label = sealed
  ? compact
    ? 'sealed'
    : 'sealed · gate-passed'
  : compact
    ? 'gate-passed'
    : `gate-passed · ${discipline}`;
// The tooltip spells out what the genre gate actually checks — a seed's contract is a different
// shape (seven sections, a detect-first install with per-step acceptance, a cited install origin,
// a runnable verify, a fixed five-row report) than a recipe's eleven sections + neutrality + scars.
const seedGate =
  'a summary plus seven sections in order, a detect-first install with per-step acceptance, a cited install origin, a runnable verify, and a fixed five-row report';
const tip =
  noun === 'seed'
    ? sealed
      ? `Sealed: this seed still hashes (sha256) to the value committed in .sporo/registry.yaml, verified at build and re-checked by CI on every push — recompute it yourself from the repo. It also passes the genre gate (${seedGate}). Not a security scan.`
      : `Passes the genre gate: ${seedGate}. Not a seal and not a security scan.`
    : sealed
      ? 'Sealed: this recipe still hashes (sha256) to the value committed in .sporo/registry.yaml, verified at build and re-checked by CI on every push — recompute it yourself from the repo. It also passes the genre gate (a summary plus eleven sections in order, neutrality, earned scars). Not a security scan.'
      : 'Passes the genre gate: a summary plus eleven sections in order, neutrality (no leaked paths or product names), and earned scars. Not a seal and not a security scan.';
---

<span
  title={tip}
  style="display:inline-flex;align-items:center;gap:.4rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.68rem;letter-spacing:.09em;text-transform:uppercase;font-weight:600;color:var(--accent);background:var(--accent-soft);border-radius:99px;padding:.24rem .6rem;white-space:nowrap"
>
  {
    sealed ? (
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="4" y="11" width="16" height="9" rx="2" />
        <path d="M8 11V7a4 4 0 0 1 8 0v4" />
      </svg>
    ) : (
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3l7 3v5c0 4.6-3.1 7.9-7 9-3.9-1.1-7-4.4-7-9V6z" />
        <path d="M9 12l2 2 4-4" />
      </svg>
    )
  }
  {label}
</span>
