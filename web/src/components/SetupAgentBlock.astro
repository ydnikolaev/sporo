---
// The agent-mode setup block, byte-identical wherever it is embedded (the hero SETUP card and the
// header setup popover both import it). Single-sourced content from lib/setup.ts — the prompt, the
// two deep-links, and the live seal state — so the two surfaces can never disagree. It carries NO
// content props on purpose: the surrounding surface owns its own framing (a large card vs a compact
// popover), this owns the invariant payload. The copy/track JS is class-scoped (no ids), so several
// instances on one page (hero + popover on the homepage) coexist without collision.
import GateBadge from './GateBadge.astro';
import { SETUP_PROMPT, seedMdUrl, seedMarkdown, seedFileName, seedSealed } from '../lib/setup.ts';
const glyph = 'width:15px;height:15px;flex:none';
---

<div class="setup-agent" data-seed-md={seedMarkdown} data-seed-file={seedFileName}>
  <div class="sa-head">
    <svg class="sa-mark" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="4.2" fill="var(--accent)"></circle><circle cx="11" cy="2.6" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="18.6" cy="7.4" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="16.9" cy="16.9" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="5.1" cy="16.9" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="3.4" cy="7.4" r="1.5" fill="var(--accent)" opacity=".75"></circle></svg>
    <span class="sa-title">Hand it the seed</span>
    <span class="sa-badge"><GateBadge compact={true} sealed={seedSealed} noun="seed" /></span>
  </div>
  <p class="sa-lead">Give any agent this line. It reads the sealed <b>sporo</b> seed — a human-auditable install recipe, not a script — then works through it in your repo, detecting first and proving each step.</p>
  <div class="sa-prompt">
    <code class="sa-prompt-text">{SETUP_PROMPT}</code>
    <button type="button" class="setup-prompt-copy" data-copy={SETUP_PROMPT} title="copy the setup line" aria-label="Copy the setup line">
      <span class="setup-prompt-copy-label">copy</span>
    </button>
  </div>
  <div class="sa-links">
    <button type="button" class="sa-link sa-copy-seed" aria-label="Copy the full sporo seed as Markdown">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={glyph} aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="sa-copy-seed-label">copy seed</span>
    </button>
    <a href={seedMdUrl} download={seedFileName} class="sa-link sa-download-seed" data-seed-action="download">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={glyph} aria-hidden="true"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
      <span>download .md</span>
    </a>
  </div>
  <p class="sa-note">Or read it first: <a href={seedMdUrl}>the seed as Markdown ↗</a> — every step is there to review before an agent runs it.</p>
</div>

<style>
  .setup-agent {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
  }
  .sa-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .sa-mark {
    width: 20px;
    height: 20px;
    flex: none;
  }
  .sa-title {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .sa-badge {
    margin-left: auto;
  }
  .sa-lead {
    margin: 0;
    font-family: system-ui, sans-serif;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--muted);
    text-wrap: pretty;
  }
  .sa-lead b {
    color: var(--ink);
    font-weight: 600;
  }
  .sa-prompt {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: 0.65rem;
    overflow: hidden;
    background: var(--card);
  }
  .sa-prompt-text {
    flex: 1;
    display: flex;
    align-items: center;
    min-width: 0;
    padding: 0.7rem 0.85rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--ink);
    word-break: break-all;
  }
  .setup-prompt-copy {
    border: none;
    border-left: 1px solid var(--line);
    background: transparent;
    color: var(--accent);
    font: inherit;
    font-size: 0.74rem;
    padding: 0 1rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .setup-prompt-copy:hover {
    background: var(--accent-soft);
  }
  .sa-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .sa-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex: 1 1 9rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    background: var(--card);
    color: var(--ink);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }
  .sa-link svg {
    color: var(--muted);
    transition: color 0.15s ease;
  }
  .sa-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
  }
  .sa-link:hover svg {
    color: var(--accent);
  }
  .sa-note {
    margin: 0;
    font-family: system-ui, sans-serif;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--muted);
  }
  .sa-note a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .setup-prompt-copy,
    .sa-link,
    .sa-link svg {
      transition: none;
    }
  }
</style>

<script>
  // Copy the setup prompt — a string we already hold (data-copy), so plain writeText is safe in
  // every browser (no gesture-consuming fetch ahead of it). Class-scoped querySelectorAll, so every
  // instance on the page (hero card + header popover) is wired without an id collision. Runs once —
  // Astro bundles this module a single time however many <SetupAgentBlock/> render.
  document.querySelectorAll('.setup-prompt-copy').forEach((el) => {
    const btn = el as HTMLButtonElement;
    const label = btn.querySelector('.setup-prompt-copy-label');
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        if (label) {
          const original = label.textContent;
          label.textContent = 'copied ✓';
          setTimeout(() => {
            label.textContent = original;
          }, 1600);
        }
        if (window.gtag) {
          window.gtag('event', 'copy_setup_prompt');
          window.gtag('event', 'agent_handoff', { handoff_method: 'copy_setup_prompt' });
        }
      } catch (e) {
        console.warn('copy setup prompt failed:', e);
      }
    });
  });

  // Copy the whole seed as Markdown. The bytes are already in the page (data-seed-md on the block),
  // so this is a plain writeText of a local string — no fetch, no cross-origin gesture problem, and
  // it behaves the same in local preview and in production. Each block owns its own copy of the seed
  // text, so several instances (hero + header popover) never collide.
  document.querySelectorAll('.sa-copy-seed').forEach((el) => {
    const btn = el as HTMLButtonElement;
    const block = btn.closest('.setup-agent') as HTMLElement | null;
    const label = btn.querySelector('.sa-copy-seed-label');
    btn.addEventListener('click', async () => {
      const md = block?.dataset.seedMd;
      if (!md) return;
      try {
        await navigator.clipboard.writeText(md);
        if (label) {
          const original = label.textContent;
          label.textContent = 'copied ✓';
          setTimeout(() => {
            label.textContent = original;
          }, 1600);
        }
        if (window.gtag) {
          window.gtag('event', 'agent_handoff', { handoff_method: 'copy_seed', context: 'setup' });
        }
      } catch (e) {
        console.warn('copy seed failed:', e);
      }
    });
  });

  // The download link is a real <a download> to the seed's .md twin (works with JS off); the click
  // only carries the funnel event.
  document.querySelectorAll('.setup-agent [data-seed-action="download"]').forEach((el) => {
    el.addEventListener('click', () => {
      if (window.gtag) {
        window.gtag('event', 'agent_handoff', { handoff_method: 'download_seed', context: 'setup' });
      }
    });
  });
</script>
