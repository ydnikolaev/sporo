---
// The agent-mode setup block, byte-identical wherever it is embedded (the hero SETUP card and the
// header setup popover both import it). Single-sourced content from lib/setup.ts — the prompt, the
// two deep-links, and the live seal state — so the two surfaces can never disagree. It carries NO
// content props on purpose: the surrounding surface owns its own framing (a large card vs a compact
// popover), this owns the invariant payload. The copy/track JS is class-scoped (no ids), so several
// instances on one page (hero + popover on the homepage) coexist without collision.
import GateBadge from './GateBadge.astro';
import { SETUP_PROMPT, chatgptUrl, claudeUrl, seedSealed } from '../lib/setup.ts';
const glyph = 'width:15px;height:15px;flex:none';
---

<div class="setup-agent">
  <div class="sa-head">
    <svg class="sa-mark" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="4.2" fill="var(--accent)"></circle><circle cx="11" cy="2.6" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="18.6" cy="7.4" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="16.9" cy="16.9" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="5.1" cy="16.9" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="3.4" cy="7.4" r="1.5" fill="var(--accent)" opacity=".75"></circle></svg>
    <span class="sa-title">Hand it the seed</span>
    <span class="sa-badge"><GateBadge compact={true} sealed={seedSealed} noun="seed" /></span>
  </div>
  <p class="sa-lead">Give any agent this line — it fetches the sealed <b>sporo</b> seed and self-installs, detecting first and proving each step.</p>
  <div class="sa-prompt">
    <code class="sa-prompt-text">{SETUP_PROMPT}</code>
    <button type="button" class="setup-prompt-copy" data-copy={SETUP_PROMPT} title="copy the setup prompt" aria-label="Copy the setup prompt">
      <span class="setup-prompt-copy-label">copy</span>
    </button>
  </div>
  <div class="sa-links">
    <a href={chatgptUrl} target="_blank" rel="noopener" class="sa-link" data-agent-provider="chatgpt">
      <svg viewBox="0 0 24 24" fill="currentColor" style={glyph} aria-hidden="true"><path d="M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z"/></svg>
      <span>Ask ChatGPT</span><span class="sa-ext" aria-hidden="true">↗</span>
    </a>
    <a href={claudeUrl} class="sa-link" data-agent-provider="claude">
      <svg viewBox="0 0 24 24" fill="currentColor" style={glyph} aria-hidden="true"><path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z"/></svg>
      <span>Ask Claude</span><span class="sa-ext" aria-hidden="true">↗</span>
    </a>
  </div>
</div>

<style>
  .setup-agent {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
  }
  .sa-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .sa-mark {
    width: 20px;
    height: 20px;
    flex: none;
  }
  .sa-title {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .sa-badge {
    margin-left: auto;
  }
  .sa-lead {
    margin: 0;
    font-family: system-ui, sans-serif;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--muted);
    text-wrap: pretty;
  }
  .sa-lead b {
    color: var(--ink);
    font-weight: 600;
  }
  .sa-prompt {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: 0.65rem;
    overflow: hidden;
    background: var(--card);
  }
  .sa-prompt-text {
    flex: 1;
    display: flex;
    align-items: center;
    min-width: 0;
    padding: 0.7rem 0.85rem;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--ink);
    word-break: break-all;
  }
  .setup-prompt-copy {
    border: none;
    border-left: 1px solid var(--line);
    background: transparent;
    color: var(--accent);
    font: inherit;
    font-size: 0.74rem;
    padding: 0 1rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .setup-prompt-copy:hover {
    background: var(--accent-soft);
  }
  .sa-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .sa-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 9rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    background: var(--card);
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }
  .sa-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-soft);
  }
  .sa-ext {
    margin-left: auto;
    color: var(--muted);
  }
  .sa-link:hover .sa-ext {
    color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .setup-prompt-copy,
    .sa-link {
      transition: none;
    }
  }
</style>

<script>
  // Copy the setup prompt — a string we already hold (data-copy), so plain writeText is safe in
  // every browser (no gesture-consuming fetch ahead of it). Class-scoped querySelectorAll, so every
  // instance on the page (hero card + header popover) is wired without an id collision. Runs once —
  // Astro bundles this module a single time however many <SetupAgentBlock/> render.
  document.querySelectorAll('.setup-prompt-copy').forEach((el) => {
    const btn = el as HTMLButtonElement;
    const label = btn.querySelector('.setup-prompt-copy-label');
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        if (label) {
          const original = label.textContent;
          label.textContent = 'copied ✓';
          setTimeout(() => {
            label.textContent = original;
          }, 1600);
        }
        if (window.gtag) {
          window.gtag('event', 'copy_setup_prompt');
          window.gtag('event', 'agent_handoff', { handoff_method: 'copy_setup_prompt' });
        }
      } catch (e) {
        console.warn('copy setup prompt failed:', e);
      }
    });
  });

  // The two agent deep-links carry the same unified funnel event AskAgent uses, tagged with the
  // provider and the setup context so a setup handoff is distinguishable from a page handoff.
  document.querySelectorAll('.setup-agent [data-agent-provider]').forEach((el) => {
    el.addEventListener('click', () => {
      const provider = (el as HTMLElement).dataset.agentProvider;
      if (provider && window.gtag) {
        window.gtag('event', 'agent_handoff', { handoff_method: provider, context: 'setup' });
      }
    });
  });
</script>
