---
// A back-to-top control, fixed bottom-right. It stays hidden until the reader is a screenful or
// two down (nothing to return to at the top), then fades in. Matched to the site: --card surface,
// --line border lifting to --accent on hover, the same 0.55rem radius as the header toggle.
// Progressive-enhancement only — no button, no JS, the page still scrolls fine.
---

<button id="scroll-top" class="scroll-top" aria-label="Back to top" title="Back to top">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 19V5" />
    <path d="M5 12l7-7 7 7" />
  </svg>
</button>

<style>
  .scroll-top {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 0.7rem;
    background: var(--card);
    color: var(--ink);
    cursor: pointer;
    box-shadow: 0 10px 30px -12px rgba(0, 0, 0, 0.35);
    opacity: 0;
    transform: translateY(0.6rem);
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease, border-color 0.15s ease;
  }
  .scroll-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .scroll-top:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-top {
      transition: opacity 0.22s ease;
      transform: none;
    }
    .scroll-top.visible {
      transform: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('scroll-top');
  if (btn) {
    const onScroll = () => btn.classList.toggle('visible', window.scrollY > 600);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    btn.addEventListener('click', () =>
      window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' }),
    );
  }
</script>
