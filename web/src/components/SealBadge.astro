---
// The honest trust badge. It claims ONLY what is mechanically true today: the recipe is sealed
// (version + content hash) and passes the genre gate (structure, neutrality, earned scars). It
// deliberately does NOT claim "no prompt injection" / "security scanned" — there is no scan behind
// that yet, and a decorative security claim is worse than none. When the publish scan lands, a
// second, earned badge joins this one (see the publish-security backlog).
interface Props {
  compact?: boolean; // card form: just "sealed" + shield; detail form spells out "gate-passed"
}
const { compact = false } = Astro.props;
const tip = 'Content-hashed seal, and it passes the genre gate — the eleven sections, neutrality (no leaked paths or product names), and earned scars. Not a security scan.';
---

<span
  title={tip}
  style="display:inline-flex;align-items:center;gap:.4rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.68rem;letter-spacing:.09em;text-transform:uppercase;font-weight:600;color:var(--accent);background:var(--accent-soft);border-radius:99px;padding:.24rem .6rem;white-space:nowrap"
>
  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3l7 3v5c0 4.6-3.1 7.9-7 9-3.9-1.1-7-4.4-7-9V6z" />
    <path d="M9 12l2 2 4-4" />
  </svg>
  {compact ? 'sealed' : 'sealed · gate-passed'}
</span>
