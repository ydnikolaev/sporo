            <div style="border:1px solid var(--line);background:var(--card);border-radius:.7rem;padding:.65rem .85rem;font-size:.85rem;color:var(--muted);display:flex;gap:.6rem;align-items:baseline"><span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.7rem;color:var(--accent)">03</span><span><b style="color:var(--ink);font-weight:600">The principles</b> — the payload; portable claims</span></div>
            <div style="border:1px solid var(--line);background:var(--card);border-radius:.7rem;padding:.65rem .85rem;font-size:.85rem;color:var(--muted);display:flex;gap:.6rem;align-items:baseline"><span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.7rem;color:var(--accent)">04</span><span><b style="color:var(--ink);font-weight:600">The ground it needs</b> — preconditions, each as a ladder</span></div>
            <div style="border:1px solid var(--line);background:var(--card);border-radius:.7rem;padding:.65rem .85rem;font-size:.85rem;color:var(--muted);display:flex;gap:.6rem;align-items:baseline"><span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.7rem;color:var(--accent)">05</span><span><b style="color:var(--ink);font-weight:600">The contracts</b> — shapes shown, each with its binding</span></div>
