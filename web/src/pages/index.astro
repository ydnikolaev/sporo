      <div aria-hidden="true" style="position:absolute;top:1.5rem;right:clamp(1rem,2.5vw,2rem);font-family:'IBM Plex Mono',ui-monospace,monospace;font-weight:600;font-size:clamp(5rem,11vw,9rem);line-height:1;color:var(--ghost);pointer-events:none;user-select:none" class="ghost" data-n="02"></div>
