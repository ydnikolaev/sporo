          <span style="border:1px solid var(--line);background:var(--card);border-radius:99px;padding:.38rem .9rem;white-space:nowrap">author</span><span style="color:var(--accent);font-weight:700">→</span>
          <span style="border:1px solid var(--line);background:var(--card);border-radius:99px;padding:.38rem .9rem;white-space:nowrap">export</span><span style="color:var(--accent);font-weight:700">→</span>
          <span style="border:1px solid var(--line);background:var(--card);border-radius:99px;padding:.38rem .9rem;white-space:nowrap">rebuilt on a foreign stack</span><span style="color:var(--accent);font-weight:700">→</span>
          <span style="border:1px solid var(--line);background:var(--card);border-radius:99px;padding:.38rem .9rem;white-space:nowrap">report back</span><span style="color:var(--accent);font-weight:700">→</span>
          <span style="border:1px solid var(--accent);background:var(--card);border-radius:99px;padding:.38rem .9rem;white-space:nowrap;color:var(--ink)">new scar → new version</span><span style="color:var(--accent);font-weight:700">↺</span>
