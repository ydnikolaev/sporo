---
import Layout from '../components/Layout.astro';
import Frame from '../components/Frame.astro';
import AgentMarks from '../components/AgentMarks.astro';
import { SITE_DATE } from '../lib/site.ts';

// The positioning page: where a recipe sits among the other ways capability "moves" — a
// pasted prompt, an installed skill, a running MCP server. The table rows are the dimensions
// that actually decide it; the Recipe column is the one this product owns. The FAQ doubles as
// FAQPage structured data (same Q/A drives the visible list and the JSON-LD mainEntity).

const columns = ['Prompt', 'Skill', 'MCP server', 'Recipe'];
type Row = { dim: string; cells: string[] }; // cells align to columns above
const rows: Row[] = [
  { dim: 'What it is', cells: ['An instruction you paste', 'A capability installed into your agent', 'A running service your agent calls', 'A self-contained file that teaches the build'] },
  { dim: 'Where it runs', cells: ['Wherever you paste it', 'The harness it is installed in', 'Your (or a vendor’s) server', 'Any harness, on the reader’s own stack'] },
  { dim: 'Crosses to a repo that has never seen yours', cells: ['No — assumes your context', 'No — tied to your harness', 'Only while the server is reachable', 'Yes — that is the whole point'] },
  { dim: 'Carries your scars', cells: ['No', 'Sometimes, implicitly', 'No', 'Yes — symptom → root cause → fix'] },
  { dim: 'Versioned & sealed', cells: ['No', 'Depends', 'Depends', 'Yes — id, version + content hash'] },
  { dim: 'Improves over time', cells: ['No', 'By editing in place', 'By redeploying', 'By report-backs → next version'] },
  { dim: 'Needs an account / server / runtime', cells: ['No', 'No', 'Yes', 'No'] },
];

const faqs = [
  {
    q: 'What is the difference between a recipe and a skill?',
    a: 'A skill runs inside your harness — it is installed into your agent and acts where it lives. A recipe is a file that rebuilds the capability in a harness that has never seen yours. sporo init installs the sporo-recipe skill, which is the thing that authors recipes.',
  },
  {
    q: 'Can’t I just share a prompt or a doc?',
    a: 'A prompt assumes your context and drifts the moment it leaves it. A recipe is a machine-gated genre: a neutrality rule (roles, never your paths or product names), a literal acceptance check on every build step, and scars recorded as symptom → root cause → fix — so an agent in another repository can actually act on it.',
  },
  {
    q: 'Do I need an account, a server, or a runtime?',
    a: 'No. sporo is one static binary and a recipe is one markdown file. Zero accounts, zero servers, zero runtimes — install with curl -fsSL sporo.dev/install.sh | sh.',
  },
  {
    q: 'What stacks does a recipe work on?',
    a: 'Any. A recipe names roles — “the facts file”, “the collector” — never your files, commands, or product, so the reader’s agent maps those roles onto its own stack and harness.',
  },
  {
    q: 'How does a recipe improve?',
    a: 'Through report-backs. A reader hits a new scar, records it, and it becomes the recipe’s next sealed version. The report-back loop, not the file format, is what compounds.',
  },
  {
    q: 'When should I not use a recipe?',
    a: 'When the capability is trivial, genuinely one-off, or so tied to your private infrastructure that nothing about it transfers. Then a prompt or an in-house skill is enough — recipes earn their gating when the capability is worth rebuilding elsewhere.',
  },
  {
    q: 'Is sporo open source?',
    a: 'Yes, Apache-2.0. One static binary for macOS, Linux and Windows, with checksummed release archives for six platforms.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const head = {
  title: 'sporo — recipe vs skill vs prompt vs MCP',
  description:
    'Where a recipe sits among the ways capability moves: a pasted prompt, an installed skill, a running MCP server, or a self-contained recipe that rebuilds the capability in any harness. Plus answers to the common questions.',
  path: '/compare.html',
  ogImage: 'og.png',
  og: {
    type: 'website' as const,
    title: 'Recipe, skill, prompt, or MCP?',
    description:
      'The one table that decides it — portability, scars, sealing, and what each one needs to run — plus the FAQ.',
  },
  twitter: {},
  jsonLd,
};
---

<Layout head={head} active="compare">
  <Frame layout="reading">
    <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.75rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:1.4rem">the comparison</div>
    <h1 style="font-size:clamp(2.4rem,6vw,3.8rem);line-height:1.04;letter-spacing:-.04em;font-weight:750;text-wrap:balance">Recipe, skill, prompt, or&nbsp;MCP?</h1>
    <p style="margin-top:1.6rem;color:var(--muted);font-size:1.12rem;max-width:52ch;text-wrap:pretty">All four move capability between agents. Only one is a self-contained artifact that rebuilds it in a repository that has never seen yours. Here is where each one actually fits.</p>
    <div style="margin-top:2.2rem"><AgentMarks label="Rebuilt by any agent" /></div>

    <div class="breakout" style="margin-top:3.5rem;overflow-x:auto;border:1px solid var(--line);border-radius:.9rem">
      <table style="border-collapse:collapse;width:100%;min-width:44rem;font-size:.92rem">
          <thead>
            <tr>
              <th style="text-align:left;padding:1rem 1.1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600;border-bottom:1px solid var(--line);vertical-align:bottom"></th>
              {columns.map((c) => {
                const own = c === 'Recipe';
                return (
                  <th style={`text-align:left;padding:1rem 1.1rem;font-size:.95rem;font-weight:700;border-bottom:1px solid var(--line);vertical-align:bottom;${own ? 'color:var(--accent);background:var(--accent-soft)' : 'color:var(--ink)'}`}>{c}</th>
                );
              })}
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => (
              <tr>
                <th scope="row" style="text-align:left;padding:.85rem 1.1rem;font-weight:600;color:var(--ink);border-bottom:1px solid var(--line);vertical-align:top;max-width:16rem">{r.dim}</th>
                {r.cells.map((cell, i) => {
                  const own = columns[i] === 'Recipe';
                  return (
                    <td style={`padding:.85rem 1.1rem;border-bottom:1px solid var(--line);vertical-align:top;${own ? 'color:var(--ink);background:var(--accent-soft);font-weight:550' : 'color:var(--muted)'}`}>{cell}</td>
                  );
                })}
              </tr>
            ))}
          </tbody>
      </table>
    </div>
    <p style="margin-top:1rem;color:var(--muted);font-size:.9rem;text-wrap:pretty">A recipe does not replace a skill — <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">sporo init</code> installs the skill that <em>writes</em> recipes. The two work together: the skill authors in your repo, the recipe travels to the next one.</p>

    <section style="margin-top:4.5rem;padding-top:3rem;border-top:1px solid var(--line)">
      <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:1.8rem">frequently asked</div>
      <div style="display:grid;gap:1.1rem">
        {faqs.map((f) => (
          <details style="background:var(--card);border:1px solid var(--line);border-radius:.9rem;padding:0 1.4rem">
            <summary style="cursor:pointer;padding:1.15rem 0;font-weight:650;font-size:1.05rem;letter-spacing:-.01em;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:1rem">
              {f.q}
              <span aria-hidden="true" style="color:var(--accent);font-family:'IBM Plex Mono',ui-monospace,monospace;flex:none">+</span>
            </summary>
            <p style="margin:0 0 1.3rem;color:var(--muted);text-wrap:pretty;max-width:64ch">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section style="margin-top:4rem;padding-top:2.5rem;border-top:1px solid var(--line)">
      <p style="color:var(--muted);text-wrap:pretty">Ready to try one? Read <a href="derived-progress-report.html" style="text-decoration:underline;text-underline-offset:3px">a real recipe</a>, or install and author your own — <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">curl -fsSL sporo.dev/install.sh | sh</code>.</p>
    </section>
  </Frame>
</Layout>

<style>
  details summary::-webkit-details-marker { display: none; }
  details[open] summary span { transform: rotate(45deg); }
  details summary span { transition: transform 0.15s ease; }
  @media (prefers-reduced-motion: reduce) {
    details summary span { transition: none; }
  }
</style>
