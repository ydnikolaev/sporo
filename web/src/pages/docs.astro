---
import Layout from '../components/Layout.astro';
import Frame from '../components/Frame.astro';
import VerifyBlock from '../components/VerifyBlock.astro';
import { surface, SPORO_VERSION, ORG_ID, WEBSITE_ID } from '../lib/site.ts';
import PageActionBar from '../components/PageActionBar.astro';

// The docs page renders from surface.json — the snapshot `sporo docs --json` emits and CI keeps
// in sync with the binary. So this page cannot claim a verb the CLI lacks, nor miss one it
// gained: add a verb, regenerate, and it appears here. The prose around the verbs (the skill,
// the group blurbs) is the only hand-written part.
const groups = [
  {
    key: 'authoring',
    title: 'Authoring',
    blurb: 'Write a recipe from the record — or a seed that brings a named tool in — gate it against its genre, seal it, and hand it over.',
  },
  {
    key: 'handover',
    title: 'Handover',
    blurb: "The reader's side: record what you built from, and hold an output to a recipe's exact contracts.",
  },
  {
    key: 'surface',
    title: 'Install surface',
    blurb: 'Put the authoring surface into a repository and keep it current.',
  },
  { key: 'binary', title: 'Binary', blurb: 'Keep the tool itself up to date.' },
];

type Flag = { name: string; default?: string; usage: string };
type Verb = {
  use: string;
  name: string;
  short: string;
  group: string;
  flags?: Flag[];
  subcommands?: Verb[];
};
const verbs = surface.verbs as Verb[];
const byGroup = (key: string) =>
  verbs.filter((v) => v.group === key).sort((a, b) => a.name.localeCompare(b.name));

const head = {
  title: 'sporo — CLI command reference',
  description:
    'The sporo command surface: every verb, its purpose and flags, generated from the binary itself — plus the sporo-recipe skill that drives an agent through authoring a recipe.',
  path: '/docs.html',
  mdMirror: 'docs.md',
  ogImage: 'og-docs.png',
  og: {
    type: 'website' as const,
    title: 'sporo — command reference',
    description:
      "Every verb the sporo CLI carries, grouped and generated from the binary — plus the sporo-recipe skill's harvest → draft → lint → seal → export cycle.",
  },
  twitter: {},
  jsonLd: {
    '@type': 'TechArticle',
    headline: 'sporo command reference',
    author: { '@id': ORG_ID },
    publisher: { '@id': ORG_ID },
    isPartOf: { '@id': WEBSITE_ID },
    inLanguage: 'en',
    image: 'https://sporo.dev/og-docs.png',
    mainEntityOfPage: 'https://sporo.dev/docs.html',
  },
};
---

<Layout head={head} active="docs">
  <Frame layout="reading">
    <PageActionBar title="sporo — command reference" path="/docs.html" mdUrl="docs.md">
      <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600">documentation</div>
    </PageActionBar>
    <div style="padding:0 0 3rem">
      <h1 style="font-size:clamp(2.4rem,6vw,4rem);line-height:1.02;letter-spacing:-.045em;font-weight:760;max-width:18ch">Every verb the binary carries.</h1>
      <p style="margin-top:1.6rem;font-size:clamp(1.02rem,1.7vw,1.2rem);color:var(--muted);max-width:60ch;text-wrap:pretty">This page is generated from the CLI itself — the same snapshot <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">sporo docs --json</code> emits, kept in sync by a build gate. Read the authoring rules with <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">sporo genre</code>.</p>
    </div>

    <section style="position:relative;border-top:1px solid var(--line)">
      <div style="padding:3.5rem 0">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:1.4rem"><span style="color:var(--accent);font-weight:600">the skill</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">what init installs</span></div>
        <div style="background:var(--card);border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:.9rem;padding:1.5rem 1.6rem;max-width:60rem">
          <h2 style="font-size:1.15rem;letter-spacing:-.01em;margin-bottom:.7rem"><code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.92em;color:var(--ink)">sporo-recipe</code> — the authoring skill</h2>
          <p style="color:var(--muted);text-wrap:pretty"><code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">sporo init</code> writes this skill into your agent. It walks the agent through the cycle below — reading the project's record, not its own memory — and leaves you one file to review.</p>
          <div style="margin-top:1.2rem;display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;color:var(--muted)">
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">harvest</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">draft</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">lint</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">seal</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--accent);border-radius:99px;padding:.34rem .8rem;color:var(--ink)">export</span>
          </div>
        </div>
      </div>
    </section>

    <section style="position:relative;border-top:1px solid var(--line)">
      <div style="padding:3.5rem 0">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:1.4rem"><span style="color:var(--accent);font-weight:600">the seed skill</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">also installed by init</span></div>
        <div style="background:var(--card);border:1px solid var(--line);border-left:3px solid var(--accent);border-radius:.9rem;padding:1.5rem 1.6rem;max-width:60rem">
          <h2 style="font-size:1.15rem;letter-spacing:-.01em;margin-bottom:.7rem"><code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.92em;color:var(--ink)">sporo-seed</code> — the seed-authoring skill</h2>
          <p style="color:var(--muted);text-wrap:pretty"><code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">sporo init</code> writes this skill alongside <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;color:var(--ink)">sporo-recipe</code>. Where a recipe teaches an agent to <em>build</em> a capability, a seed teaches one to bring a <strong style="color:var(--ink);font-weight:600">named tool</strong> in and stand it up — detect it, install it from an origin the seed vouches for, prove it runs, and account for every move to the human. The skill drives the <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9em;background:var(--accent-soft);color:var(--ink);padding:.1em .4em;border-radius:.35em">sporo seed</code> verbs — read the tool's current truth and run the install, scaffold, gate against the genre, seal, export — and leaves you one file to review. The genre in full: <a href="what-is-a-seed.html" style="color:var(--accent);text-decoration:underline;text-underline-offset:3px">what is a seed</a>.</p>
          <div style="margin-top:1.2rem;display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;color:var(--muted)">
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">new</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">lint</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--line);border-radius:99px;padding:.34rem .8rem">seal</span><span style="color:var(--accent);font-weight:700">→</span>
            <span style="border:1px solid var(--accent);border-radius:99px;padding:.34rem .8rem;color:var(--ink)">export</span>
          </div>
        </div>
      </div>
    </section>

    {groups.map((g) => (
      <section style="position:relative;border-top:1px solid var(--line)">
        <div style="padding:3.5rem 0">
          <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:1rem"><span style="color:var(--accent);font-weight:600">{g.title}</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">{byGroup(g.key).length} {byGroup(g.key).length === 1 ? 'verb' : 'verbs'}</span></div>
          <p style="color:var(--muted);max-width:60ch;margin-bottom:1.8rem;text-wrap:pretty">{g.blurb}</p>
          <div style="display:grid;gap:.9rem">
            {byGroup(g.key).map((v) => (
              <div style="background:var(--card);border:1px solid var(--line);border-radius:.9rem;padding:1.15rem 1.3rem">
                <div style="display:flex;align-items:center;gap:.75rem">
                  <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9rem;color:var(--accent);font-weight:600;flex:1;min-width:0;overflow-wrap:anywhere">sporo {v.use}</div>
                  <button class="verb-copy hov-btn" data-copy={`sporo ${v.use}`} aria-label={`Copy command: sporo ${v.use}`} style="flex:none;border:1px solid var(--line);background:transparent;color:var(--muted);font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;padding:.28rem .6rem;border-radius:.45rem;cursor:pointer">copy</button>
                </div>
                <p style="margin-top:.4rem;color:var(--muted);font-size:.95rem">{v.short}</p>
                {v.flags && v.flags.length > 0 && (
                  <div style="margin-top:.8rem;display:grid;gap:.35rem">
                    {v.flags.map((f) => (
                      <div style="display:flex;gap:.7rem;font-size:.86rem;color:var(--muted);flex-wrap:wrap">
                        <code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;color:var(--ink);white-space:nowrap">--{f.name}{f.default ? `=${f.default}` : ''}</code>
                        <span>{f.usage}</span>
                      </div>
                    ))}
                  </div>
                )}
                {v.subcommands && v.subcommands.length > 0 && (
                  <div style="margin-top:.9rem;padding-top:.8rem;border-top:1px solid var(--line);display:grid;gap:.6rem">
                    {v.subcommands.map((s) => (
                      <div>
                        <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.84rem;color:var(--accent)">sporo {v.name} {s.use}</div>
                        <p style="margin-top:.25rem;color:var(--muted);font-size:.9rem">{s.short}</p>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    <section style="border-top:1px solid var(--line)">
      <div style="padding:3rem 0">
        <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:1.2rem">verify your download</div>
        <VerifyBlock divider={false} posture={false} />
        <p style="margin-top:1.8rem;color:var(--muted)">The full policy, continuous-scan posture and vulnerability disclosure live on the <a href="security.html" style="color:var(--accent);text-decoration:underline;text-underline-offset:3px">security &amp; provenance</a> page.</p>
      </div>
    </section>

    <section style="border-top:1px solid var(--line)">
      <div style="padding:3rem 0;color:var(--muted);font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem">
        generated from sporo <b style="color:var(--ink)">{SPORO_VERSION}</b> · <a href="https://github.com/ydnikolaev/sporo" style="text-decoration:underline;text-underline-offset:3px">source on github</a>
      </div>
    </section>
  </Frame>
</Layout>

<script>
  // One delegated handler for every verb card's copy button — copies the command template
  // (sporo <use>, placeholders and all) and flips the label to a confirmation briefly.
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.verb-copy');
    if (!btn) return;
    const text = btn.getAttribute('data-copy') || '';
    if (navigator.clipboard) navigator.clipboard.writeText(text);
    const prev = btn.textContent;
    btn.textContent = 'copied ✓';
    setTimeout(() => {
      btn.textContent = prev;
    }, 1600);
  });
</script>
