---
import Layout from '../components/Layout.astro';
import Frame from '../components/Frame.astro';
import GateBadge from '../components/GateBadge.astro';
import Publisher from '../components/Publisher.astro';
import { listCorpus, formatDate } from '../lib/corpus.ts';
import { WEBSITE_ID } from '../lib/site.ts';
import AskAgent from '../components/AskAgent.astro';

// The storefront. Every recipe in the corpus, as a card that links to its detail page. The list
// is generated from the corpus at build, so publishing a recipe (a new `.md` under recipes/) adds
// a card and a page with no edit here.
const recipes = listCorpus()
  .map(({ slug, meta, sealed }) => ({
    slug,
    version: meta.version ?? '',
    title: meta.title ?? slug,
    headline: (meta.title ?? slug).split(' — ')[0],
    problem: meta.problem ?? '',
    date: formatDate(meta.date),
    sealed,
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const head = {
  title: 'sporo — the recipe corpus',
  description:
    'Every transferable build recipe in the sporo corpus: real, gate-checked, versioned recipes an AI agent can rebuild from in a repository that has never seen yours.',
  path: '/recipes.html',
  mdMirror: 'recipes.md',
  og: {
    type: 'website' as const,
    title: 'sporo recipes — the corpus',
    description:
      'Real, gate-checked, versioned build recipes an AI agent can rebuild from in a repository that has never seen yours.',
  },
  twitter: {},
  jsonLd: {
    '@type': 'CollectionPage',
    name: 'sporo recipes',
    url: 'https://sporo.dev/recipes.html',
    description: 'The sporo recipe corpus — transferable build recipes for AI agents.',
    isPartOf: { '@id': WEBSITE_ID },
    inLanguage: 'en',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: recipes.map((r, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://sporo.dev/${r.slug}.html`,
        name: r.headline,
      })),
    },
  },
};
---

<Layout head={head} active="recipes">
  <Frame layout="wide">
    <section style="position:relative;padding:clamp(4rem,9vh,7rem) clamp(1.25rem,3vw,2.5rem) 3rem;overflow:clip">
      <div aria-hidden="true" style="position:absolute;top:1.5rem;right:clamp(1rem,2.5vw,2rem);font-family:'IBM Plex Mono',ui-monospace,monospace;font-weight:600;font-size:clamp(5rem,11vw,9rem);line-height:1;color:var(--ghost);pointer-events:none;user-select:none">✦</div>
      <div style="display:flex;justify-content:flex-end;margin-bottom:1.25rem;position:relative;z-index:1"><AskAgent title="The sporo recipe corpus" path="/recipes.html" mdUrl="recipes.md" /></div>
      <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:1.4rem"><span style="color:var(--accent);font-weight:600">◉</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">the corpus</span></div>
      <h1 style="font-size:clamp(2.4rem,6vw,4rem);line-height:1.02;letter-spacing:-.045em;font-weight:760;max-width:16ch;text-wrap:balance">Recipes, ready to hand over.</h1>
      <p style="margin-top:1.4rem;max-width:58ch;color:var(--muted);font-size:clamp(1.02rem,1.7vw,1.2rem);text-wrap:pretty">Each is a real build, distilled: principles, contracts and scars an AI agent germinates back into the capability — on its own stack, in a repository that has never seen yours. New to the idea? <a href="what-is-a-recipe.html" style="text-decoration:underline;text-underline-offset:3px">What a recipe is →</a></p>
      <p style="margin-top:1rem;max-width:58ch;color:var(--muted);font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.78rem;line-height:1.6;text-wrap:pretty">Every recipe here is sealed — its bytes hash (sha256) to a value committed in the public registry — and gate-passed, re-checked on every push. <a href="https://github.com/ydnikolaev/sporo/actions/workflows/ci.yml" style="color:var(--accent);text-decoration:underline;text-underline-offset:3px">Verified in CI ↗</a></p>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,400px));justify-content:start;gap:1rem;margin-top:3.2rem">
        {recipes.map((r) => (
          <a
            href={`${r.slug}.html`}
            class="recipe-card"
            style="display:flex;flex-direction:column;border:1px solid var(--line);border-radius:1rem;background:var(--card);padding:1.5rem 1.5rem 1.3rem;text-decoration:none;color:inherit;transition:border-color .18s ease,transform .18s ease"
          >
            <div style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;margin-bottom:.9rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase">
              <span style="color:var(--accent);font-weight:600">v{r.version}</span>
              {r.date && <span style="color:var(--muted)">{r.date}</span>}
            </div>
            <h2 title={r.title} style="font-size:1.25rem;line-height:1.18;letter-spacing:-.02em;font-weight:680;color:var(--ink)">{r.headline}</h2>
            <p style="margin-top:.7rem;color:var(--muted);font-size:.94rem;line-height:1.5;text-wrap:pretty;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical">{r.problem}</p>
            <div style="margin-top:1.3rem;padding-top:.9rem;border-top:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;gap:.6rem;flex-wrap:wrap">
              <Publisher size={20} link={false} />
              <GateBadge compact={true} sealed={r.sealed} />
            </div>
          </a>
        ))}
      </div>
    </section>

    <section style="padding:0 clamp(1.25rem,3vw,2.5rem) clamp(4rem,9vh,6rem)">
      <div style="border-top:1px solid var(--line);padding-top:clamp(2.5rem,5vh,3.5rem)">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:1.4rem"><span style="color:var(--accent);font-weight:600">how these are verified</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span></div>
        <h2 style="font-size:clamp(1.7rem,4vw,2.6rem);line-height:1.06;letter-spacing:-.035em;font-weight:730;max-width:20ch">Trust you can recompute — and honesty about the rest.</h2>
        <p style="margin-top:1.2rem;max-width:60ch;color:var(--muted);font-size:clamp(1rem,1.6vw,1.12rem);text-wrap:pretty">Two claims on every recipe are mechanical and public. A third that isn't real yet gets no badge — a decorative trust mark is worse than none.</p>

        <div style="margin-top:2.8rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem">
          <div style="border:1px solid var(--line);border-radius:1rem;background:var(--card);padding:1.5rem">
            <div style="display:inline-flex;align-items:center;gap:.5rem;color:var(--accent)">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="9" rx="2" /><path d="M8 11V7a4 4 0 0 1 8 0v4" /></svg>
              <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;font-weight:600">sealed</span>
            </div>
            <p style="margin-top:.9rem;color:var(--muted);font-size:.92rem;line-height:1.55;text-wrap:pretty">Each recipe's exact bytes hash (SHA-256) to a fingerprint committed in the public registry. Open any recipe and click the seal — your browser refetches the source <em>and</em> the registry from GitHub and recomputes the hash. Nothing to trust from this site.</p>
          </div>
          <div style="border:1px solid var(--line);border-radius:1rem;background:var(--card);padding:1.5rem">
            <div style="display:inline-flex;align-items:center;gap:.5rem;color:var(--accent)">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.6-3.1 7.9-7 9-3.9-1.1-7-4.4-7-9V6z" /><path d="M9 12l2 2 4-4" /></svg>
              <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;font-weight:600">gate-passed</span>
            </div>
            <p style="margin-top:.9rem;color:var(--muted);font-size:.92rem;line-height:1.55;text-wrap:pretty"><code style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.86em;background:var(--accent-soft);color:var(--ink);padding:.05em .35em;border-radius:.3em">sporo lint</code> checks every recipe against the genre — the eleven sections in order, neutrality (no leaked paths or product names), and earned scars — on every push. The <a href="https://github.com/ydnikolaev/sporo/actions/workflows/ci.yml" style="color:var(--accent);text-decoration:underline;text-underline-offset:3px">green run ↗</a> is the proof.</p>
          </div>
          <div style="border:1px solid var(--line);border-radius:1rem;background:var(--card);padding:1.5rem">
            <div style="display:inline-flex;align-items:center;gap:.5rem;color:var(--muted)">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke-dasharray="3 3" /></svg>
              <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;font-weight:600">not claimed yet</span>
            </div>
            <p style="margin-top:.9rem;color:var(--muted);font-size:.92rem;line-height:1.55;text-wrap:pretty">No "scanned for prompt injection" or "verified publisher" mark — those need a real scan and cryptographic attestation we haven't built. When they exist they'll be earned, not decorative. A recipe is still text an agent reads: audit the prose before you run it.</p>
          </div>
        </div>
      </div>
    </section>
  </Frame>
</Layout>

<style>
  .recipe-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .recipe-card {
      transition: none;
    }
    .recipe-card:hover {
      transform: none;
    }
  }
</style>
