---
// The site used to prove itself with one hardcoded "example" recipe here. Recipes now have a
// real listing (/recipes.html) and a page per recipe (/<slug>.html), so this URL redirects to
// the recipe it used to be — external links, old sitemap entries and OG shares still land.
const target = 'derived-progress-report.html';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={`https://sporo.dev/${target}`} />
    <meta name="robots" content="noindex" />
    <title>Redirecting to the recipe…</title>
  </head>
  <body>
    <p>This page moved to <a href={target}>the recipe</a>.</p>
  </body>
</html>
