---
import Layout from '../components/Layout.astro';
import Frame from '../components/Frame.astro';
import AgentMarks from '../components/AgentMarks.astro';
import GateBadge from '../components/GateBadge.astro';
import Publisher from '../components/Publisher.astro';
import { readRecipe, listCorpus, adoptionSections, formatDate } from '../lib/corpus.ts';

// One detail page per corpus recipe, generated from the slugs listCorpus() enumerates. The
// page IS the recipe, read straight from the embedded corpus at build — not a retyped copy.
// Routes stay flat (`/<slug>.html`, like every other page) so the relative nav/footer links
// in the shared chrome resolve; a nested path would ship a dead navbar.
export function getStaticPaths() {
  return listCorpus().map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const recipe = readRecipe(slug as string);
const m = recipe.meta;
const headline = (m.title ?? '').split(' — ')[0];
const mdHref = `${slug}.md`;
const date = formatDate(m.date);
// The adoption protocol (Adopt it here / Report back) is what `sporo export` appends — the page
// shows the recipe as a reader actually receives it, not the bare source.
const adopt = adoptionSections();

const head = {
  title: `${headline} — a sporo recipe`,
  description: m.problem ?? 'A real sporo recipe, rendered: its gated sections, its earned scars, and the export you would hand an agent.',
  path: `/${slug}.html`,
  mdMirror: mdHref,
  ogImage: 'og-example.png',
  og: {
    type: 'article' as const,
    title: `${headline} — a sporo recipe`,
    description: m.problem ?? 'A real sporo recipe in full — gated sections, earned scars, and the export an agent rebuilds from.',
  },
  twitter: {},
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: m.title || 'A sporo recipe',
    author: { '@type': 'Organization', name: 'sporo', url: 'https://sporo.dev/' },
    publisher: { '@type': 'Organization', name: 'sporo', url: 'https://sporo.dev/' },
    mainEntityOfPage: `https://sporo.dev/${slug}.html`,
  },
};
---

<Layout head={head} active="recipes">
  <Frame layout="reading">
    <div style="padding:0 0 3rem">
      <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:1.2rem"><a href="recipes.html" style="color:var(--muted);text-decoration:none">recipes</a> · v{m.version}</div>
      <h1 style="font-size:clamp(2rem,5vw,3.4rem);line-height:1.04;letter-spacing:-.04em;font-weight:760;max-width:26ch">{m.title}</h1>
      <div style="margin-top:1.3rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;color:var(--muted)">
        <Publisher size={22} prefix="by" />
        <span aria-hidden="true" style="width:1px;height:1rem;background:var(--line)"></span>
        <GateBadge />
        {date && <span aria-hidden="true" style="width:1px;height:1rem;background:var(--line)"></span>}
        {date && <span>verified {date}</span>}
      </div>
      <p style="margin-top:1.5rem;font-size:clamp(1.02rem,1.7vw,1.2rem);color:var(--muted);max-width:62ch;text-wrap:pretty">{m.problem}</p>

      <div style="margin-top:2rem;display:flex;align-items:center;gap:.9rem;flex-wrap:wrap;border:1px solid var(--line);border-radius:.85rem;background:var(--card);padding:.7rem .8rem .7rem 1rem">
        <span style="display:inline-flex;align-items:center;gap:.55rem">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="4.2" fill="var(--accent)"></circle><circle cx="11" cy="2.6" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="18.6" cy="7.4" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="16.9" cy="16.9" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="5.1" cy="16.9" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="3.4" cy="7.4" r="1.5" fill="var(--accent)" opacity=".75"></circle></svg>
          <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.9rem;font-weight:600;letter-spacing:-.01em;color:var(--ink)">sporo recipe</span>
        </span>
        <span style="margin-left:auto;display:flex;gap:.5rem;flex-wrap:wrap">
          <button id="copy-recipe" data-md={mdHref} style="display:inline-flex;align-items:center;gap:.4rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;font-weight:600;border:1px solid var(--accent);color:var(--bg);background:var(--accent);border-radius:.55rem;padding:.55rem 1.05rem;cursor:pointer;transition:opacity .15s ease">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
            copy the recipe
          </button>
          <a href={mdHref} download style="display:inline-flex;align-items:center;gap:.4rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;border:1px solid var(--line);color:var(--ink);background:var(--bg);border-radius:.55rem;padding:.55rem 1.05rem;text-decoration:none">download .md ↓</a>
        </span>
      </div>

      <p style="margin-top:1.2rem;font-size:.85rem;color:var(--muted);font-family:'IBM Plex Mono',ui-monospace,monospace;max-width:62ch;text-wrap:pretty">What a reader receives is the <a href="what-is-a-recipe.html" style="text-decoration:underline;text-underline-offset:3px">exported</a> form — this, with the adoption protocol appended. Every section below was distilled from one live implementation: its build record, its release history, its fix commits, and the scars only a real build leaves.</p>
    </div>

    <section style="border-top:1px solid var(--line)">
      <div style="padding:1.7rem 0">
        <AgentMarks label="Works with any agent" />
      </div>
    </section>

    {recipe.introHtml.trim() && (
      <section style="border-top:1px solid var(--line)">
        <div style="padding:3rem 0" class="prose" set:html={recipe.introHtml}></div>
      </section>
    )}

    <section style="border-top:1px solid var(--line)">
      <div style="padding:2.5rem 0">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:2rem"><span style="color:var(--accent);font-weight:600">the recipe, section by section</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">each gated · scars open</span></div>
        <div style="display:grid;gap:.7rem">
          {recipe.sections.map((s, i) => (
            <details open={s.open} style="border:1px solid var(--line);border-radius:.8rem;background:var(--card);overflow:hidden">
              <summary style="cursor:pointer;padding:1rem 1.3rem;display:flex;align-items:center;gap:.9rem;list-style:none">
                <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;color:var(--accent)">{String(i + 1).padStart(2, '0')}</span>
                <h2 style="margin:0;font-size:1rem;font-weight:600;letter-spacing:-.01em">{s.title}</h2>
              </summary>
              <div class="prose" style="padding:0 1.3rem 1.3rem" set:html={s.html}></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section style="border-top:1px solid var(--line)">
      <div style="padding:2.5rem 0">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:.4rem"><span style="color:var(--accent);font-weight:600">the handover protocol</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">appended on export</span></div>
        <p style="color:var(--muted);font-size:.9rem;max-width:60ch;text-wrap:pretty">These two sections are the same in every recipe — `sporo export` appends them so the reader knows how to bring the capability into a repository the author never saw, and what to send back.</p>
        {adopt.map((s) => (
          <div style="margin-top:2.2rem">
            <h2 style="font-size:1.15rem;font-weight:660;letter-spacing:-.01em;color:var(--ink)">{s.title}</h2>
            <div class="prose" style="margin-top:.7rem" set:html={s.html}></div>
          </div>
        ))}
      </div>
    </section>
  </Frame>

  <script>
    const btn = document.getElementById('copy-recipe');
    if (btn) {
      btn.addEventListener('click', async () => {
        try {
          const res = await fetch(btn.dataset.md);
          const text = await res.text();
          if (navigator.clipboard) await navigator.clipboard.writeText(text);
          const original = btn.textContent;
          btn.textContent = 'copied ✓';
          setTimeout(() => {
            btn.textContent = original;
          }, 1600);
        } catch {
          /* clipboard denied or offline — the download link still works */
        }
      });
    }
  </script>
</Layout>

<style is:global>
  #copy-recipe:hover { opacity: 0.88; }
  .prose {
    color: var(--muted);
    max-width: 68ch;
    line-height: 1.66;
  }
  .prose h3 {
    color: var(--ink);
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    margin: 1.6rem 0 0.6rem;
  }
  .prose h4 {
    color: var(--ink);
    font-size: 1rem;
    margin: 1.3rem 0 0.5rem;
  }
  .prose p {
    margin: 0.7rem 0;
    text-wrap: pretty;
  }
  .prose strong {
    color: var(--ink);
  }
  .prose ul,
  .prose ol {
    margin: 0.7rem 0;
    padding-left: 1.3rem;
    display: grid;
    gap: 0.4rem;
  }
  .prose blockquote {
    margin: 1rem 0;
    padding: 0.2rem 0 0.2rem 1.1rem;
    border-left: 3px solid var(--accent);
    color: var(--ink);
  }
  .prose code {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.88em;
    background: var(--accent-soft);
    color: var(--ink);
    padding: 0.1em 0.4em;
    border-radius: 0.35em;
  }
  .prose pre {
    background: #0e120f;
    color: #d9e4da;
    border: 1px solid #ffffff14;
    border-radius: 0.7rem;
    padding: 1rem 1.1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .prose pre code {
    background: none;
    color: inherit;
    padding: 0;
    font-size: 0.84rem;
    line-height: 1.7;
  }
  .prose table {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
    /* A recipe table comes from rendered markdown, so it can't opt into the frame's breakout
       column the way a hand-authored table can — this is the fallback: scroll it inside the
       reading column instead of letting a wide one push the whole page sideways. */
    display: block;
    overflow-x: auto;
  }
  .prose th,
  .prose td {
    border: 1px solid var(--line);
    padding: 0.5rem 0.7rem;
    text-align: left;
  }
  .prose th {
    color: var(--ink);
    background: var(--accent-soft);
  }
  .prose a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose summary::-webkit-details-marker {
    display: none;
  }
</style>
