---
import Layout from '../components/Layout.astro';
import Frame from '../components/Frame.astro';
import AgentMarks from '../components/AgentMarks.astro';
import GateBadge from '../components/GateBadge.astro';
import Publisher from '../components/Publisher.astro';
import { readRecipe, listCorpus, adoptionSections, formatDate, sealHash } from '../lib/corpus.ts';

// One detail page per corpus recipe, generated from the slugs listCorpus() enumerates. The
// page IS the recipe, read straight from the embedded corpus at build — not a retyped copy.
// Routes stay flat (`/<slug>.html`, like every other page) so the relative nav/footer links
// in the shared chrome resolve; a nested path would ship a dead navbar.
export function getStaticPaths() {
  return listCorpus().map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const recipe = readRecipe(slug as string);
const m = recipe.meta;
const headline = (m.title ?? '').split(' — ')[0];
const mdHref = `${slug}.md`;
const date = formatDate(m.date);
// The adoption protocol (Adopt it here / Report back) is what `sporo export` appends — the page
// shows the recipe as a reader actually receives it, not the bare source.
const adopt = adoptionSections();
const stats = recipe.stats;

// The seal's public anchors, all on GitHub — the trust panel verifies against THESE, never against
// anything sporo.dev asserts. `hash` is only the fingerprint shown; the browser check refetches the
// recipe AND the registry from raw.githubusercontent and compares the two GitHub-sourced values.
const GH_RAW = 'https://raw.githubusercontent.com/ydnikolaev/sporo/main';
const seal = {
  hash: sealHash(slug), // display only
  recipeRawUrl: `${GH_RAW}/recipes/${slug}.md`,
  registryRawUrl: `${GH_RAW}/.sporo/registry.yaml`,
  registryBlobUrl: 'https://github.com/ydnikolaev/sporo/blob/main/.sporo/registry.yaml',
  ciUrl: 'https://github.com/ydnikolaev/sporo/actions/workflows/ci.yml',
};
// Preview rows: number + title for every gated section, plus a derived count-tag on the two
// sections that carry one (contracts → N bound, scars → N scars). All from the recipe + stats —
// nothing hand-entered, so the panel can never drift from the recipe it previews.
const rows = recipe.sections.map((s, i) => {
  const scar = /scar/i.test(s.title);
  const contract = /contract/i.test(s.title);
  return {
    n: String(i + 1).padStart(2, '0'),
    title: s.title,
    scar,
    tag: scar ? `${stats.scars} scars` : contract ? `${stats.contracts} bound` : '',
  };
});

const head = {
  title: `${headline} — a sporo recipe`,
  description: m.problem ?? 'A real sporo recipe, rendered: its gated sections, its earned scars, and the export you would hand an agent.',
  path: `/${slug}.html`,
  mdMirror: mdHref,
  ogImage: 'og-example.png',
  og: {
    type: 'article' as const,
    title: `${headline} — a sporo recipe`,
    description: m.problem ?? 'A real sporo recipe in full — gated sections, earned scars, and the export an agent rebuilds from.',
  },
  twitter: {},
  jsonLd: {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: m.title || 'A sporo recipe',
    author: { '@type': 'Organization', name: 'sporo', url: 'https://sporo.dev/' },
    publisher: { '@type': 'Organization', name: 'sporo', url: 'https://sporo.dev/' },
    mainEntityOfPage: `https://sporo.dev/${slug}.html`,
  },
};
---

<Layout head={head} active="recipes">
  <Frame layout="reading">
    <div style="padding:0 0 3rem">
      <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.75rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);font-weight:600;margin-bottom:1.2rem"><a href="recipes.html" style="color:var(--muted);text-decoration:none">recipes</a> · v{m.version}</div>
      <h1 style="font-size:clamp(2rem,5vw,3.4rem);line-height:1.04;letter-spacing:-.04em;font-weight:760;max-width:26ch">{m.title}</h1>
      <div style="margin-top:1.3rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;color:var(--muted)">
        <Publisher size={22} prefix="by" />
        <span aria-hidden="true" style="width:1px;height:1rem;background:var(--line)"></span>
        {recipe.sealed ? (
          <button id="seal-toggle" type="button" aria-expanded="false" aria-controls="seal-proof" class="seal-toggle" title="How this seal is verified">
            <GateBadge sealed={true} />
            <svg class="seal-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
          </button>
        ) : (
          <GateBadge sealed={false} />
        )}
        {date && <span aria-hidden="true" style="width:1px;height:1rem;background:var(--line)"></span>}
        {date && <span>verified {date}</span>}
      </div>

      {recipe.sealed && (
        <div id="seal-proof" class="seal-proof" hidden data-slug={slug} data-recipe-url={seal.recipeRawUrl} data-registry-url={seal.registryRawUrl}>
          <p class="seal-plain">This recipe is <strong>sealed</strong>: these exact bytes have not changed since it was published. A SHA-256 fingerprint of the source is committed to a public registry — change one character and it no longer matches, and this badge is gone. You don't have to take our word for it.</p>

          <div class="seal-block">
            <div class="seal-k">Reproduce it yourself — the recipe and its fingerprint both live on GitHub, not here:</div>
            <div class="seal-cmd">
              <code>curl -s {seal.recipeRawUrl} | shasum -a 256</code>
              <button type="button" class="seal-copy" data-copy={`curl -s ${seal.recipeRawUrl} | shasum -a 256`}>copy</button>
            </div>
            <p class="seal-muted">The result equals the hash committed in the <a href={seal.registryBlobUrl} target="_blank" rel="noopener">public registry ↗</a> — <code class="seal-hash">{seal.hash}</code>. Neither side is served by this site.</p>
          </div>

          <div class="seal-block">
            <button id="seal-verify" type="button" class="seal-verify">Verify in your browser</button>
            <span id="seal-result" class="seal-result" role="status" aria-live="polite"></span>
            <p class="seal-muted">A convenience demo: your browser refetches the recipe <em>and</em> the registry from GitHub and recomputes the hash — it trusts nothing from this page. View source to confirm.</p>
          </div>

          <div class="seal-links">
            <a href={seal.registryBlobUrl} target="_blank" rel="noopener">the registry ↗</a>
            <a href={seal.recipeRawUrl} target="_blank" rel="noopener">the source ↗</a>
            <a href={seal.ciUrl} target="_blank" rel="noopener">the CI gate ↗</a>
          </div>
        </div>
      )}
      <p style="margin-top:1.5rem;font-size:clamp(1.02rem,1.7vw,1.2rem);color:var(--muted);max-width:62ch;text-wrap:pretty">{m.problem}</p>

      <div id="recipe-bar" data-open="false" style="margin-top:2rem;position:relative;border:1px solid var(--line);border-radius:.85rem;background:var(--card);overflow:hidden">
        <!-- A faint spore drifts behind the bar, like the home hero. Positioning lives on the
             wrapper and the 90s spin on the inner SVG — an animated `transform` on the same
             element would clobber the vertical anchor. The wrapper's `top` shifts by state (see
             CSS): centred high when collapsed, dropped to the bottom corner when expanded, so it
             fills dead space without landing on the stat cards. Decorative: aria-hidden. -->
        <div class="rc-spore" aria-hidden="true"><svg viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="4.2" fill="var(--accent)"></circle><circle cx="11" cy="2.6" r="1.5" fill="var(--accent)"></circle><circle cx="18.6" cy="7.4" r="1.5" fill="var(--accent)"></circle><circle cx="16.9" cy="16.9" r="1.5" fill="var(--accent)"></circle><circle cx="5.1" cy="16.9" r="1.5" fill="var(--accent)"></circle><circle cx="3.4" cy="7.4" r="1.5" fill="var(--accent)"></circle></svg></div>
        <div style="position:relative;display:flex;align-items:center;justify-content:space-between;gap:1rem 1.2rem;flex-wrap:wrap;padding:.75rem .8rem">
          <div style="display:flex;align-items:center;gap:.7rem;flex-wrap:wrap;min-width:0">
            <span style="display:inline-flex;align-items:center;gap:.5rem">
              <svg width="18" height="18" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="4.2" fill="var(--accent)"></circle><circle cx="11" cy="2.6" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="18.6" cy="7.4" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="16.9" cy="16.9" r="1.5" fill="var(--accent)" opacity=".75"></circle><circle cx="5.1" cy="16.9" r="1.5" fill="var(--accent)" opacity=".55"></circle><circle cx="3.4" cy="7.4" r="1.5" fill="var(--accent)" opacity=".75"></circle></svg>
              <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.85rem;font-weight:600;letter-spacing:-.01em;color:var(--accent)">sporo recipe</span>
            </span>
            <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;color:var(--muted);display:inline-flex;align-items:center;gap:.55rem"><span aria-hidden="true" style="width:1px;height:.9rem;background:var(--line)"></span>{stats.sections} sections · {stats.scars} scars · {recipe.sealed ? 'sealed ' : 'v'}{m.version}</span>
          </div>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap">
            <button id="copy-recipe" data-md={mdHref} style="display:inline-flex;align-items:center;gap:.4rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;font-weight:600;border:1px solid var(--accent);color:var(--bg);background:var(--accent);border-radius:.55rem;padding:.5rem 1rem;cursor:pointer;transition:opacity .15s ease">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
              <span id="copy-label">copy</span>
            </button>
            <a href={mdHref} download class="rc-ghost" style="display:inline-flex;align-items:center;gap:.4rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;color:var(--ink);background:var(--bg);border:1px solid var(--line);border-radius:.55rem;padding:.5rem 1rem;text-decoration:none;transition:border-color .15s ease,color .15s ease">download .md ↓</a>
            <button id="recipe-toggle" class="rc-ghost" aria-expanded="false" aria-controls="recipe-preview" title="preview the recipe" style="display:inline-flex;align-items:center;justify-content:center;gap:.45rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.82rem;color:var(--muted);background:var(--bg);border:1px solid var(--line);border-radius:.55rem;padding:.5rem .85rem;cursor:pointer;transition:border-color .15s ease,color .15s ease">
              <span id="recipe-toggle-label" style="display:inline-block;min-width:3.2rem;text-align:left">preview</span>
              <svg class="rc-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </button>
          </div>
        </div>

        <div id="recipe-preview" class="recipe-grid" style="position:relative;border-top:1px solid var(--line);grid-template-columns:minmax(0,1.1fr) minmax(0,1fr)">
          <div style="padding:1.1rem 1.2rem;min-width:0;border-right:1px solid var(--line)">
            <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.75rem">the {stats.sections} gated sections</div>
            <div style="display:grid;gap:.32rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.78rem;text-transform:lowercase">
              {rows.map((r) => (
                <div style="display:flex;align-items:baseline;gap:.6rem">
                  <span style="color:var(--accent);opacity:.55">{r.n}</span>
                  <span style={`color:${r.scar ? '#c8892f' : 'var(--ink)'};overflow:hidden;text-overflow:ellipsis;white-space:nowrap`}>{r.title}</span>
                  {r.tag && <span style={`margin-left:auto;flex:none;font-size:.68rem;color:${r.scar ? '#c8892f' : 'var(--accent)'}`}>{r.tag}</span>}
                </div>
              ))}
            </div>
          </div>
          <div style="padding:1.1rem 1.2rem;display:flex;flex-direction:column">
            <div style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:.75rem">what you'd hand an agent</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem">
              <div style="border-radius:.55rem;background:var(--accent-soft);padding:.8rem .9rem"><div style="font-size:1.5rem;font-weight:700;letter-spacing:-.02em;line-height:1">{stats.sections}</div><div style="font-family:'IBM Plex Mono',ui-monospace,monospace;margin-top:.25rem;font-size:.66rem;color:var(--muted)">gated sections</div></div>
              <div style="border-radius:.55rem;background:var(--accent-soft);padding:.8rem .9rem"><div style="font-size:1.5rem;font-weight:700;letter-spacing:-.02em;line-height:1;color:var(--accent)">{stats.scars}</div><div style="font-family:'IBM Plex Mono',ui-monospace,monospace;margin-top:.25rem;font-size:.66rem;color:var(--muted)">earned scars</div></div>
              <div style="border-radius:.55rem;background:var(--accent-soft);padding:.8rem .9rem"><div style="font-size:1.5rem;font-weight:700;letter-spacing:-.02em;line-height:1">{stats.contracts}</div><div style="font-family:'IBM Plex Mono',ui-monospace,monospace;margin-top:.25rem;font-size:.66rem;color:var(--muted)">bound contracts</div></div>
              <div style="border-radius:.55rem;background:var(--accent-soft);padding:.8rem .9rem"><div style="font-size:1.5rem;font-weight:700;letter-spacing:-.02em;line-height:1">1</div><div style="font-family:'IBM Plex Mono',ui-monospace,monospace;margin-top:.25rem;font-size:.66rem;color:var(--muted)">self-contained file</div></div>
            </div>
            <p style="margin-top:1rem;font-size:.8rem;line-height:1.5;color:var(--muted);text-wrap:pretty">Readable before it runs — audit the prose, then let an agent build it on your stack.</p>
          </div>
        </div>
      </div>

      <p style="margin-top:1.2rem;font-size:.85rem;color:var(--muted);font-family:'IBM Plex Mono',ui-monospace,monospace;max-width:62ch;text-wrap:pretty">What a reader receives is the <a href="what-is-a-recipe.html" style="text-decoration:underline;text-underline-offset:3px">exported</a> form — this, with the adoption protocol appended. Every section below was distilled from one live implementation: its build record, its release history, its fix commits, and the scars only a real build leaves.</p>
    </div>

    <section style="border-top:1px solid var(--line)">
      <div style="padding:1.7rem 0">
        <AgentMarks label="Works with any agent" />
      </div>
    </section>

    {recipe.introHtml.trim() && (
      <section style="border-top:1px solid var(--line)">
        <div style="padding:3rem 0" class="prose" set:html={recipe.introHtml}></div>
      </section>
    )}

    <section style="border-top:1px solid var(--line)">
      <div style="padding:2.5rem 0">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:2rem"><span style="color:var(--accent);font-weight:600">the recipe, section by section</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">each gated · scars open</span></div>
        <div style="display:grid;gap:.7rem">
          {recipe.sections.map((s, i) => (
            <details open={s.open} style="border:1px solid var(--line);border-radius:.8rem;background:var(--card);overflow:hidden">
              <summary style="cursor:pointer;padding:1rem 1.3rem;display:flex;align-items:center;gap:.9rem;list-style:none">
                <span style="font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.72rem;color:var(--accent)">{String(i + 1).padStart(2, '0')}</span>
                <h2 style="margin:0;font-size:1rem;font-weight:600;letter-spacing:-.01em">{s.title}</h2>
              </summary>
              <div class="prose" style="padding:0 1.3rem 1.3rem" set:html={s.html}></div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section style="border-top:1px solid var(--line)">
      <div style="padding:2.5rem 0">
        <div style="display:flex;align-items:center;gap:1rem;font-family:'IBM Plex Mono',ui-monospace,monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:.4rem"><span style="color:var(--accent);font-weight:600">the handover protocol</span><span style="flex:0 0 3.5rem;height:1px;background:var(--line)"></span><span style="color:var(--muted)">appended on export</span></div>
        <p style="color:var(--muted);font-size:.9rem;max-width:60ch;text-wrap:pretty">These two sections are the same in every recipe — `sporo export` appends them so the reader knows how to bring the capability into a repository the author never saw, and what to send back.</p>
        {adopt.map((s) => (
          <div style="margin-top:2.2rem">
            <h2 style="font-size:1.15rem;font-weight:660;letter-spacing:-.01em;color:var(--ink)">{s.title}</h2>
            <div class="prose" style="margin-top:.7rem" set:html={s.html}></div>
          </div>
        ))}
      </div>
    </section>
  </Frame>

  <script>
    // Copy: swap only the label span so the icon survives (setting the button's textContent would
    // wipe the SVG). Fetches the .md mirror and writes it to the clipboard.
    const btn = document.getElementById('copy-recipe');
    const clabel = document.getElementById('copy-label');
    if (btn) {
      btn.addEventListener('click', async () => {
        try {
          const res = await fetch(btn.dataset.md);
          const text = await res.text();
          if (navigator.clipboard) await navigator.clipboard.writeText(text);
          if (clabel) {
            const original = clabel.textContent;
            clabel.textContent = 'copied ✓';
            setTimeout(() => {
              clabel.textContent = original;
            }, 1600);
          }
        } catch {
          /* clipboard denied or offline — the download link still works */
        }
      });
    }

    // Preview toggle: reveal the derived section-map / stat panel. Progressive enhancement — the
    // recipe itself is fully rendered below; the panel is a summary, so no-JS just hides it.
    const bar = document.getElementById('recipe-bar');
    const toggle = document.getElementById('recipe-toggle');
    const preview = document.getElementById('recipe-preview');
    const tlabel = document.getElementById('recipe-toggle-label');
    if (bar && toggle && preview) {
      toggle.addEventListener('click', () => {
        const next = bar.dataset.open !== 'true';
        bar.dataset.open = String(next);
        toggle.setAttribute('aria-expanded', String(next));
        if (tlabel) tlabel.textContent = next ? 'hide' : 'preview';
      });
    }

    // Seal proof: expand the panel, and let the reader re-verify the seal WITHOUT trusting this
    // page. The check refetches both the recipe and the registry from raw.githubusercontent and
    // compares the two GitHub-sourced values; sporo.dev's copy of the hash is never the authority.
    const sealToggle = document.getElementById('seal-toggle');
    const sealProof = document.getElementById('seal-proof');
    if (sealToggle && sealProof) {
      sealToggle.addEventListener('click', () => {
        const willOpen = sealProof.hasAttribute('hidden');
        if (willOpen) sealProof.removeAttribute('hidden');
        else sealProof.setAttribute('hidden', '');
        sealToggle.setAttribute('aria-expanded', String(willOpen));
        sealToggle.classList.toggle('open', willOpen);
      });
    }

    // Small copy buttons inside the panel (the shasum command).
    document.querySelectorAll('.seal-copy').forEach((b) => {
      b.addEventListener('click', async () => {
        try {
          if (navigator.clipboard) await navigator.clipboard.writeText(b.dataset.copy);
          const t = b.textContent;
          b.textContent = 'copied ✓';
          setTimeout(() => { b.textContent = t; }, 1400);
        } catch {}
      });
    });

    const verifyBtn = document.getElementById('seal-verify');
    const resultEl = document.getElementById('seal-result');
    if (verifyBtn && resultEl && sealProof) {
      verifyBtn.addEventListener('click', async () => {
        resultEl.textContent = 'verifying…';
        resultEl.className = 'seal-result pending';
        try {
          const [recRes, regRes] = await Promise.all([
            fetch(sealProof.dataset.recipeUrl),
            fetch(sealProof.dataset.registryUrl),
          ]);
          if (!recRes.ok || !regRes.ok) throw new Error('unreachable');
          const buf = await recRes.arrayBuffer();
          const regText = await regRes.text();
          const esc = sealProof.dataset.slug.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
          const m = regText.match(new RegExp('\\n\\s+' + esc + ':\\s*\\n[\\s\\S]*?hash:\\s*(sha256:[0-9a-f]{64})'));
          if (!m) throw new Error('no-seal');
          const digest = await crypto.subtle.digest('SHA-256', buf);
          const got = 'sha256:' + Array.from(new Uint8Array(digest)).map((x) => x.toString(16).padStart(2, '0')).join('');
          if (got === m[1]) {
            resultEl.textContent = '✓ matches — recomputed from GitHub just now';
            resultEl.className = 'seal-result ok';
          } else {
            resultEl.textContent = '✗ does not match';
            resultEl.className = 'seal-result bad';
          }
        } catch {
          // A network hiccup or parse miss is not tampering — never render it as ✗.
          resultEl.textContent = "couldn't verify in-browser — reproduce it with the command above";
          resultEl.className = 'seal-result muted';
        }
      });
    }
  </script>
</Layout>

<style is:global>
  #copy-recipe:hover { opacity: 0.88; }
  .rc-ghost:hover { border-color: var(--accent); color: var(--accent); }
  .rc-chev { transition: transform 0.2s ease; }
  #recipe-bar[data-open='true'] .rc-chev { transform: rotate(180deg); }
  /* Visibility is driven by data-open, not the [hidden] attribute — an inline display would beat
     the UA `[hidden]{display:none}` rule and leak the panel open on load. */
  #recipe-preview { display: none; }
  #recipe-bar[data-open='true'] #recipe-preview { display: grid; }
  /* The drifting spore. Collapsed: centred near the top of the short bar. Expanded: dropped to
     the bottom-right corner, clear of the stat cards. The `top` shift eases as the panel opens. */
  .rc-spore {
    position: absolute;
    right: -1.5rem;
    top: 1.4rem;
    width: 14rem;
    height: 14rem;
    transform: translateY(-50%);
    pointer-events: none;
    transition: top 0.25s ease;
  }
  #recipe-bar[data-open='true'] .rc-spore {
    top: calc(100% - 2rem);
  }
  .rc-spore svg {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.12;
    animation: spin 90s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .rc-spore svg { animation: none; }
    .rc-spore { transition: none; }
  }
  /* The preview is a two-column map on desktop; on a phone it stacks, and the divider between the
     two panels moves from the right edge to the bottom of the first. */
  @media (max-width: 600px) {
    .recipe-grid { grid-template-columns: 1fr !important; }
    .recipe-grid > div:first-child {
