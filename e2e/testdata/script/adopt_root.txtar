# --root points adopt at a repository other than the working directory: the verbatim copy
# and the registry entry land under sub/.sporo, never beside the cwd.
mkdir sub
mkdir sub/.claude
exec sporo init --root sub

exec sporo seal --root sub crm-feed
exec sporo export --root sub crm-feed
cp stdout handoff.md

exec sporo adopt --root sub handoff.md
stdout 'sporo adopt: crm-feed 1\.0\.0 \(source: handoff\.md\)'

exists sub/.sporo/adopted/crm-feed.md
grep 'adopted:' sub/.sporo/registry.yaml

# the cwd itself was never touched — no stray adopted home landed outside --root's target.
! exists .sporo/adopted

-- sub/.sporo/recipes/crm-feed.md --
