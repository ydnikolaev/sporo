# list shows this project's own recipes alongside the official corpus, each under its own
# origin prefix — a project recipe (this repo's build) must read distinctly from an official
# one (shipped read-only in the binary), or an author would edit the wrong copy.
exec sporo list
stdout 'official daily-progress-report'
stdout 'project  nightly-digest'

