# A body change under an unchanged version is exactly the silent mutation the registry exists
# to catch: seal refuses it and demands a version bump before it will re-seal. Bumping the
# version alongside the same change lets the re-seal through.
mkdir .claude
exec sporo init

exec sporo seal nightly-digest
stdout 'sporo seal: nightly-digest 1\.0\.0'

# the body changes but `version:` stays put — content drifted from its seal.
cp changed-unbumped.md .sporo/recipes/nightly-digest.md
! exec sporo seal nightly-digest
stderr 'changed since it was sealed at 1\.0\.0, but `version:` still says 1\.0\.0'
stderr 'bump the version, then seal'

# the same body change, this time with the version bumped — the re-seal now succeeds.
cp changed-bumped.md .sporo/recipes/nightly-digest.md
exec sporo seal nightly-digest
stdout 'sporo seal: nightly-digest 1\.1\.0'

-- .sporo/recipes/nightly-digest.md --
