# --contract narrows the check to one exact-bound shape by its 1-based index, so a recipe
# that carries several fences can be conformed one at a time — and the untouched ones are
# skipped entirely, not silently passed.
mkdir .claude
exec sporo init

exec sporo seal crm-feed
stdout 'sporo seal: crm-feed 1\.0\.0'

exec sporo export crm-feed --stdout
cp stdout handoff.md

# contract #1 against a feed shaped for it, addressed explicitly.
exec sporo conform handoff.md feed.json --contract 1
stdout 'contract #1 ✓'
! stdout 'contract #2'

# contract #2 against a feed shaped for it — #1 is skipped, not checked.
exec sporo conform handoff.md ping.json --contract 2
stdout 'contract #2 ✓'
! stdout 'contract #1'

# without --contract, every exact-bound shape is checked — the feed only satisfies #1.
! exec sporo conform handoff.md feed.json
stdout 'contract #1 ✓'
stderr 'contract #2 \$\.ok: missing'

-- .sporo/recipes/crm-feed.md --
