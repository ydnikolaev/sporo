# feedback add files a reader's report-back against a recipe this project authors. The channel
# is content-addressed: the exact same bytes filed twice must land as ONE entry on disk, because
# the loop's natural failure is a reader re-pasting the same report into a second session and
# the author merging one scar twice.
mkdir .claude
exec sporo init

exec sporo feedback add nightly-digest report.md
stdout 'sporo feedback: filed \.sporo/feedback/nightly-digest/001-768e340c\.md'
exists .sporo/feedback/nightly-digest/001-768e340c.md

# The identical bytes, filed again, resolve to the same path — no second entry lands on disk.
exec sporo feedback add nightly-digest report.md
stdout 'sporo feedback: filed \.sporo/feedback/nightly-digest/001-768e340c\.md'
! exists .sporo/feedback/nightly-digest/002-768e340c.md

# Argument validation: add wants exactly a slug and a report file, no more, no fewer.
! exec sporo feedback add nightly-digest
stderr 'accepts 2 arg\(s\), received 1'

! exec sporo feedback add
stderr 'accepts 2 arg\(s\), received 0'

! exec sporo feedback add a b c
stderr 'accepts 2 arg\(s\), received 3'

# Filing against a recipe this project does not author is refused, loudly and by name.
! exec sporo feedback add ghost-recipe report.md
stderr 'no recipe "ghost-recipe" in this project''s home'

-- .sporo/recipes/nightly-digest.md --
