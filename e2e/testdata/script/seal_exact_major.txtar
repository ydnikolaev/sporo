# The fleet rule: an exact-bound contract is somebody else's parser. Renaming a field inside
# one under a MINOR bump ships a break wearing a compatible version number, so seal refuses it
# and demands a MAJOR instead. Bumping to MAJOR lets the same rename through.
mkdir .claude
exec sporo init

exec sporo seal crm-feed
stdout 'sporo seal: crm-feed 1\.0\.0'

# the exact-bound field is renamed, but the bump is only MINOR.
cp crm-feed-minor.md .sporo/recipes/crm-feed.md
! exec sporo seal crm-feed
stderr 'changes an exact-bound contract'
stderr 'MAJOR version \(1\.0\.0 → at least 2\.0\.0\), not 1\.1\.0'

# the same rename, this time behind a MAJOR bump — the seal now succeeds.
cp crm-feed-major.md .sporo/recipes/crm-feed.md
exec sporo seal crm-feed
stdout 'sporo seal: crm-feed 2\.0\.0'

-- .sporo/recipes/crm-feed.md --
