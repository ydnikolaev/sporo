# ADR-005 discipline: a recipe where every contract is Binding: adapt declares no exact-bound
# shape at all — conform is a clean, green no-op, not a failure the author owes anyone.
mkdir .claude
exec sporo init

exec sporo seal nightly-digest
stdout 'sporo seal: nightly-digest 1\.0\.0'

exec sporo conform nightly-digest whatever.json
stdout 'this recipe declares no exact-bound contracts — every shape is Binding: adapt'

-- .sporo/recipes/nightly-digest.md --
