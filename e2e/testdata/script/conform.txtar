# conform is the reader's half of `Binding: exact`: it checks a candidate output against the
# EXPORTED recipe alone — the only document a reader ever has, no checkout of the author's
# repo required. An exact-bound feed passes; a renamed field fails with a path naming exactly
# what the consumer will miss.
mkdir .claude
exec sporo init

exec sporo seal crm-feed
stdout 'sporo seal: crm-feed 1\.0\.0'

exec sporo export crm-feed
cp stdout handoff.md
stdout '## Adopt it here'
! stdout '<!-- SSOT SOURCE'

# an exact-bound feed, bound to the exported document alone.
cp good-feed.json feed.json
exec sporo conform handoff.md feed.json
stdout 'contract #1 ✓'

# the field the contract promises (`tallied`) got renamed back to `counted` — the export is
# the only ground truth a reader has, and it must catch the drift structurally.
cp bad-feed.json feed.json
! exec sporo conform handoff.md feed.json
stderr '\$\.tallied: missing — the consumer parses this field and will starve without it'
stderr '\$\.counted: not in the contract — an extra field is a dialect the consumer never agreed to'
stderr 'the output does not hold the promise its recipe makes'

-- .sporo/recipes/crm-feed.md --
<!-- SSOT SOURCE (this project). -->

