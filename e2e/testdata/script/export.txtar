# export hands a sealed recipe to a stranger repository as ONE self-contained file: the
# adoption protocol appended, the provenance banner stripped — house business nobody outside
# this repo needs.
mkdir .claude
exec sporo init

exec sporo lint .sporo/recipes/
stdout 'conformant and neutral'

exec sporo seal nightly-digest
stdout '1\.0\.0'

# --stdout prints the composed document for piping.
exec sporo export nightly-digest --stdout
stdout '## Adopt it here'
stdout '## Report back'
! stdout '<!-- SSOT SOURCE'

# the default WRITES the file — export exists to hand a recipe over, not to fill a terminal.
exec sporo export nightly-digest
stdout 'wrote .sporo/exports/nightly-digest.md'
exists .sporo/exports/nightly-digest.md
grep '## Adopt it here' .sporo/exports/nightly-digest.md
! grep '<!-- SSOT SOURCE' .sporo/exports/nightly-digest.md

-- .sporo/recipes/nightly-digest.md --
<!-- SSOT SOURCE (this project). -->

