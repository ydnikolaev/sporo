# adopt is the reader-side seal: it records a handed-over exported recipe verbatim, anchors
# `slug version` from its frontmatter into the registry, and — because this recipe carries an
# exact-bound contract — points the reader at the exact check to wire into this repo's own
# CI. The export is produced in-script via seal+export, the same file a real handover hands
# over.
mkdir .claude
exec sporo init

exec sporo seal crm-feed
stdout 'sporo seal: crm-feed 1\.0\.0 \(local, sha256:'

exec sporo export crm-feed --stdout
cp stdout handoff.md

exec sporo adopt handoff.md
stdout 'sporo adopt: crm-feed 1\.0\.0 \(source: handoff\.md\)'
stdout 'exact contract\(s\) — wire `sporo conform handoff\.md <your output>` into this repo'

exists .sporo/adopted/crm-feed.md
grep 'adopted:' .sporo/registry.yaml
grep 'version: 1.0.0' .sporo/adopted/crm-feed.md

-- .sporo/recipes/crm-feed.md --
