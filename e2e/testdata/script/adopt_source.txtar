# --source records where `pull` should re-fetch from later, independent of the file argument
# adopt actually reads — the two commonly differ: the file is a local copy, the source is the
# fleet's own address for it.
mkdir .claude
exec sporo init

exec sporo seal crm-feed
exec sporo export crm-feed --stdout
cp stdout handoff.md

exec sporo adopt handoff.md --source https://recipes.example/crm-feed.md
stdout 'sporo adopt: crm-feed 1\.0\.0 \(source: https://recipes\.example/crm-feed\.md\)'

grep 'source: https://recipes.example/crm-feed.md' .sporo/registry.yaml

-- .sporo/recipes/crm-feed.md --
