# pull re-checks an adopted recipe against its recorded source. Read-only by default: when
# the source moves forward with a changed exact-bound contract, pull reports the delta and
# shouts about it; --apply is the explicit second step that refreshes the stored copy and the
# registry, and list then shows the recipe at its applied version.
mkdir .claude
exec sporo init

exec sporo export crm-feed
cp stdout handoff.md

exec sporo adopt handoff.md
stdout 'sporo adopt: crm-feed 2\.0\.0 \(source: handoff\.md\)'
stdout 'exact contract\(s\) — wire `sporo conform handoff\.md <your output>`'

# The source moves forward — a MAJOR bump that renames the exact-bound field — the case a
# consumer-feeding build must not sleep through.
cp bumped/crm-feed.md handoff.md

exec sporo pull
stdout 'sporo pull: crm-feed 2\.0\.0 → 3\.0\.0'
stdout 'an EXACT contract changed \(that is a major\)'
stdout '\(report only'
! stdout 'applied —'

exec sporo pull --apply
stdout 'sporo pull: crm-feed 2\.0\.0 → 3\.0\.0'
stdout 'applied — the stored copy and the record now say 3\.0\.0'

exec sporo list
stdout 'adopted  crm-feed \(3\.0\.0\)'

-- .sporo/recipes/crm-feed.md --
