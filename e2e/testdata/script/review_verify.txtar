# review verify closes the loop: it validates the returned JSON against the fixed schema
# and, only when every verdict is clean, records the tally beside the recipe's seal in the
# registry. A review binds a version and a content hash, so it requires a SEALED recipe.
mkdir .claude
exec sporo init

exec sporo seal nightly-digest
stdout '1\.0\.0'

exec sporo review nightly-digest

exec sporo review verify nightly-digest verdict.json
stdout 'mean 8\.0/10'
stdout 'adopt'
grep 'reviews:' .sporo/registry.yaml
grep 'nightly-digest' .sporo/registry.yaml

# arg validation: at least a slug and one verdict file.
! exec sporo review verify
stderr 'at least 2 arg\(s\)'
! exec sporo review verify nightly-digest
stderr 'at least 2 arg\(s\)'
! exec sporo review verify nightly-digest missing.json
stderr 'no such file or directory'

