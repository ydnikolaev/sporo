# feedback list reads what is filed straight off disk, per recipe, in arrival order.
mkdir .claude
exec sporo init

# No feedback yet is a state, not an error — the command stays quiet and green.
exec sporo feedback list
! stdout 'nightly-digest'

exec sporo feedback add nightly-digest report.md
exec sporo feedback list
stdout 'nightly-digest \(1 report\(s\)\)'
stdout '  \.sporo/feedback/nightly-digest/001-768e340c\.md'

# A slug argument narrows the listing to just that recipe.
exec sporo feedback list nightly-digest
stdout 'nightly-digest \(1 report\(s\)\)'

exec sporo feedback list some-other-slug
! stdout 'nightly-digest'

# Argument validation: list takes at most one slug.
! exec sporo feedback list a b
stderr 'accepts at most 1 arg\(s\), received 2'

-- .sporo/recipes/nightly-digest.md --
