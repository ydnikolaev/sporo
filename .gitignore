# build output
/bin/
/dist/

# exported recipes are derived share artifacts (source + adoption protocol), regenerated by
# `sporo export` — never source
.sporo/exports/

# go workspace files are never committed (the module builds without one — GOWORK=off is a gate)
go.work
go.work.sum

# local env / editor
.DS_Store
.env
.env.*

# ── publish boundary: private harness + planning ──────────────────────────────────
# SSOT of this list is scripts/classify-guard.sh (the gate asserts the two agree).
# These live in a separate private repo; the PUBLIC repo must never track them.
# The harness is delivered by `mate fleet pull`, not committed here.
.agents/
.claude/
.codex/
.mate/
docs/
AGENTS.md
Makefile
scripts/*
!scripts/install.sh
